# PARE configuration. Copy to .env and edit for your host.
#
# Inference manager (the llama-manager / OpenAI-compatible endpoint).
PARE_INFERENCE_URL=http://192.168.1.14:11434
PARE_MODEL=Qwen3.5-35B-A3B-Q4_K_M

# PAL vault (read-only) and collection ID.
PARE_VAULT_PATH=/home/edible/pal-vault-prod
PARE_COLLECTION_ID=vault

# Daemon socket (defaults to $XDG_RUNTIME_DIR/pare.sock).
# PARE_SOCKET_PATH=/run/user/1000/pare.sock

# User identity for logs/audit.
PARE_USERNAME=user

# Conversation history depth (number of messages to retain).
PARE_HISTORY_DEPTH=50

# Search engine (SearXNG instance).
PARE_SEARXNG_URL=http://192.168.1.14:8080

# Network fetch limits.
PARE_FETCH_MAX_BYTES=2000000
PARE_FETCH_TIMEOUT=30

# LLM response token limit.
PARE_MAX_RESPONSE_TOKENS=4096

# Batch inference (for bulk processing; optional).
PARE_BATCH_ENABLED=false
PARE_BATCH_INFERENCE_URL=http://192.168.1.14:11434
PARE_BATCH_MODEL=gemma-4-E4B-it-Q4_K_M

# Scratchpad (working memory) size limit.
PARE_SCRATCHPAD_MAX_BYTES=2048

# PARE-specific: apk_re_agents static-analysis backend.
PARE_APK_RE_AGENTS_URL=http://127.0.0.1:8000
